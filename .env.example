# Client build-time env vars. Copied into app.config.js > expo.extra at build time.
# Expo reads these via Constants.manifest.extra (see src/config.js).

# Backend API URL (must be HTTPS in production).
API_URL=https://your-api.example.com

# Cloudinary configuration. Prefer an unsigned upload preset; if you must sign,
# generate the signature on the server and remove CLOUDINARY_API_KEY from the client.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
