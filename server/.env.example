# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/demochat

# Server port (default 2000)
PORT=2000

# Secret used to sign and verify JWTs. Use a long random value in production.
JWT_SECRET=change-me-to-a-long-random-value

# Comma-separated list of origins allowed by CORS and Socket.IO.
# Example: https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=
